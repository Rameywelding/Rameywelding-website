---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import logo from '../assets/logo.png';

const year = new Date().getFullYear();
---

<footer class="border-t border-steel-700/70 bg-steel-900">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-12">
    <!-- Brand + pitch -->
    <div class="md:col-span-5">
      <Image src={logo} alt={site.name} width={480} height={267} class="h-16 w-auto sm:h-20" />
      <p class="mt-5 max-w-sm text-sm leading-relaxed text-ash">
        Welding, custom fabrication, and dirt work in Fulton, MS and across
        Northeast Mississippi. {site.credentials}.
      </p>
      <p class="mt-4 font-mono text-xs uppercase tracking-wider text-arc">
        {site.credentials} · {site.licenseDetail}
      </p>
    </div>

    <!-- Contact -->
    <div class="md:col-span-3">
      <h3 class="font-mono text-xs uppercase tracking-widest text-steel-500">Get in touch</h3>
      <ul class="mt-4 space-y-3 text-sm">
        <li>
          <a href={site.phoneHref} class="font-display text-2xl text-cream hover:text-arc">
            {site.phone}
          </a>
        </li>
        <li>
          <a href={site.emailHref} class="text-ash hover:text-arc">{site.email}</a>
        </li>
        <li class="text-ash">{site.cityState}</li>
        <li class="text-ash">{site.hours}</li>
      </ul>
      <a
        href="/#contact"
        class="mt-5 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-arc hover:text-spark"
      >
        Request a quote
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Service area -->
    <div class="md:col-span-4">
      <h3 class="font-mono text-xs uppercase tracking-widest text-steel-500">Service area</h3>
      <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm text-ash">
        {site.areas.map((a) => <li>{a}</li>)}
      </ul>
      <p class="mt-3 text-xs text-steel-500">…and surrounding Northeast Mississippi.</p>
    </div>
  </div>

  <div class="border-t border-steel-700/60">
    <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-5 text-xs text-steel-500 sm:flex-row sm:items-center sm:justify-between sm:px-6">
      <p>© {year} {site.name}. All rights reserved.</p>
      <nav class="flex gap-5" aria-label="Footer">
        {site.nav.map((item) => (
          <a href={item.href} class="hover:text-ash">{item.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
