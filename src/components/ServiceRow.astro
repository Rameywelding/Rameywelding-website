---
import type { Service } from '../data/services';
import { getServiceImages } from '../data/services';
import ServicePhoto from './ServicePhoto.astro';

interface Props {
  service: Service;
  reverse?: boolean;
}
const { service, reverse = false } = Astro.props;
const images = getServiceImages(service.slug);
---

<article
  id={service.slug}
  class="grid scroll-mt-28 items-center gap-8 lg:grid-cols-2 lg:gap-14"
>
  <!-- Text -->
  <div class:list={[reverse ? 'lg:order-2' : 'lg:order-1']}>
    <h3 class="font-display text-3xl font-bold uppercase text-cream sm:text-4xl">
      {service.title}
    </h3>
    <div class="mt-3 h-0.5 w-14 spark-rule"></div>
    <p class="mt-5 text-base leading-relaxed text-ash">{service.blurb}</p>
    <ul class="mt-6 space-y-2.5">
      {service.bullets.map((b) => (
        <li class="flex items-start gap-3 text-sm text-cream">
          <svg class="mt-1 h-4 w-4 shrink-0 text-arc" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M6.2 11.4 2.8 8l1.1-1.1 2.3 2.2 5-5L12.3 5l-6.1 6.4Z"/>
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Photo -->
  <div class:list={[reverse ? 'lg:order-1' : 'lg:order-2']}>
    <ServicePhoto images={images} title={service.title} />
  </div>
</article>
