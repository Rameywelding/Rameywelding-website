---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  title: string;
}
const { images, title } = Astro.props;
const main = images[0];
const thumbs = images.slice(1, 4);
---

{main ? (
  <figure class="space-y-3">
    <div class="overflow-hidden rounded-lg border border-steel-700 bg-steel-900 shadow-2xl shadow-black/40">
      <Image
        src={main}
        alt={`${title} — example work by Ramey's Welding Services`}
        widths={[480, 800, 1200]}
        sizes="(max-width: 1024px) 100vw, 50vw"
        class="aspect-[4/3] h-full w-full object-cover"
      />
    </div>
    {thumbs.length > 0 && (
      <div class="grid grid-cols-3 gap-3">
        {thumbs.map((img) => (
          <div class="overflow-hidden rounded-md border border-steel-700 bg-steel-900">
            <Image
              src={img}
              alt={`${title} — additional example`}
              widths={[200, 400]}
              sizes="33vw"
              class="aspect-square h-full w-full object-cover"
            />
          </div>
        ))}
      </div>
    )}
  </figure>
) : (
  <div
    class="flex aspect-[4/3] flex-col items-center justify-center gap-3 rounded-lg border border-dashed border-steel-700 bg-steel-900/60 text-center"
  >
    <svg class="h-12 w-12 text-steel-600" viewBox="0 0 48 48" fill="none" aria-hidden="true">
      <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="24" y1="6" x2="24" y2="14" />
        <line x1="24" y1="34" x2="24" y2="42" />
        <line x1="6" y1="24" x2="14" y2="24" />
        <line x1="34" y1="24" x2="42" y2="24" />
        <line x1="11" y1="11" x2="17" y2="17" />
        <line x1="31" y1="31" x2="37" y2="37" />
        <line x1="37" y1="11" x2="31" y2="17" />
        <line x1="17" y1="31" x2="11" y2="37" />
      </g>
      <circle cx="24" cy="24" r="5" fill="#ff6a1a" opacity="0.7" />
    </svg>
    <p class="font-mono text-xs uppercase tracking-wider text-steel-500">
      Project photos coming soon
    </p>
  </div>
)}
