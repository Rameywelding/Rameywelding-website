---
import { getImage } from 'astro:assets';
import { site } from '../data/site';
import { heroImage } from '../data/images';

const bg = heroImage
  ? (await getImage({ src: heroImage, width: 2000, quality: 78, format: 'webp' })).src
  : null;
---

<section class="relative isolate overflow-hidden">
  <!-- Background: photo if present, else steel -->
  <div class="absolute inset-0 -z-10">
    {bg ? (
      <img
        src={bg}
        alt=""
        class="h-full w-full object-cover object-center"
        fetchpriority="high"
      />
    ) : (
      <div
        class="h-full w-full"
        style="background:
          radial-gradient(120% 80% at 80% 0%, #20242e 0%, #14161b 45%, #0e0f12 100%);"
      ></div>
    )}
    <!-- readability + mood overlay -->
    <div
      class="absolute inset-0"
      style="background:
        linear-gradient(90deg, rgba(14,15,18,.96) 0%, rgba(14,15,18,.86) 38%, rgba(14,15,18,.45) 72%, rgba(14,15,18,.65) 100%);"
    ></div>
    <!-- faint caution-stripe texture, very low opacity -->
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background: repeating-linear-gradient(45deg, #ffc20e 0 22px, transparent 22px 60px);"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Arc-flash signature streak -->
  <svg
    class="pointer-events-none absolute inset-0 -z-[5] h-full w-full"
    viewBox="0 0 1200 700"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="streak" x1="0" y1="1" x2="1" y2="0">
        <stop offset="0%" stop-color="#ffc20e" stop-opacity="0" />
        <stop offset="55%" stop-color="#ffc20e" stop-opacity=".7" />
        <stop offset="100%" stop-color="#ff6a1a" stop-opacity=".95" />
      </linearGradient>
      <radialGradient id="bloom">
        <stop offset="0%" stop-color="#fff4dc" stop-opacity=".95" />
        <stop offset="30%" stop-color="#ff6a1a" stop-opacity=".7" />
        <stop offset="100%" stop-color="#ff6a1a" stop-opacity="0" />
      </radialGradient>
    </defs>
    <line x1="80" y1="660" x2="900" y2="120" stroke="url(#streak)" stroke-width="2.5" />
    <circle cx="900" cy="120" r="90" fill="url(#bloom)" class="hero-bloom" />
    <circle cx="900" cy="120" r="4.5" fill="#fff6e6" />
  </svg>

  <div class="mx-auto flex min-h-[88vh] max-w-6xl items-center px-4 py-24 sm:px-6">
    <div class="max-w-2xl">
      <p class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs uppercase tracking-[0.2em] text-arc">
        <span>{site.cityState}</span>
        <span class="text-steel-600">/</span>
        <span>{site.credentials}</span>
      </p>

      <h1 class="mt-6 font-display text-6xl font-extrabold uppercase text-cream sm:text-7xl lg:text-8xl">
        Steel that holds.<br />
        <span class="text-arc">Ground that's ready.</span>
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ash">
        Welding, custom fabrication, and dirt work across Northeast Mississippi.
        On the job when you need it — at the shop, on your site, or wherever the
        steel is.
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={site.phoneHref}
          class="inline-flex items-center justify-center gap-2 rounded-md bg-arc px-7 py-4 font-display text-2xl font-bold uppercase tracking-wide text-black transition-transform hover:-translate-y-0.5"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.3 1l-2.2 2.2Z"/>
          </svg>
          Call {site.phone}
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-steel-600 bg-steel-900/60 px-7 py-4 font-display text-2xl font-bold uppercase tracking-wide text-cream transition-colors hover:border-arc hover:text-arc"
        >
          Request a quote
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <p class="mt-7 font-mono text-xs uppercase tracking-wider text-steel-500">
        MIG · TIG · Stick · Fabrication · Plasma cutting · Excavation · Trenching
      </p>
    </div>
  </div>
</section>

<style>
  .hero-bloom { animation: bloom 3.6s ease-in-out infinite; transform-origin: 900px 120px; }
  @keyframes bloom {
    0%, 100% { opacity: 0.75; transform: scale(0.96); }
    50% { opacity: 1; transform: scale(1.06); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-bloom { animation: none; }
  }
</style>
