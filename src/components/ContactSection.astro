---
import { site } from '../data/site';

// Public Turnstile site key. Falls back to Cloudflare's official "always passes"
// TEST key so the form renders in local dev before real keys are set.
// Real key goes in .env as PUBLIC_TURNSTILE_SITE_KEY (see README / .env.example).
const TURNSTILE_SITE_KEY =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
---

<section id="contact" class="scroll-mt-24 bg-steel-900">
  <div class="mx-auto grid max-w-6xl gap-12 px-4 py-16 sm:px-6 sm:py-24 lg:grid-cols-2">
    <!-- Pitch + details -->
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-arc">Get a quote</p>
      <h2 class="mt-2 font-display text-4xl font-bold uppercase text-cream sm:text-5xl">
        Tell us about the job
      </h2>
      <p class="mt-5 max-w-md text-base leading-relaxed text-ash">
        Pricing depends on the job, so the fastest answer is a quick conversation.
        Call, or send the details below and we'll get right back to you.
      </p>

      <div class="mt-9 space-y-5">
        <a href={site.phoneHref} class="flex items-center gap-4 group">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-md bg-arc text-black">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.2.4 2.4.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.3 1l-2.2 2.2Z"/></svg>
          </span>
          <span>
            <span class="block font-mono text-xs uppercase tracking-wider text-steel-500">Call or text</span>
            <span class="font-display text-2xl text-cream group-hover:text-arc">{site.phone}</span>
          </span>
        </a>
        <a href={site.emailHref} class="flex items-center gap-4 group">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-md border border-steel-700 text-arc">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          </span>
          <span>
            <span class="block font-mono text-xs uppercase tracking-wider text-steel-500">Email</span>
            <span class="text-cream group-hover:text-arc">{site.email}</span>
          </span>
        </a>
        <div class="flex items-center gap-4">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-md border border-steel-700 text-arc">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 21c-4-4.5-7-7.5-7-11a7 7 0 0 1 14 0c0 3.5-3 6.5-7 11Z"/></svg>
          </span>
          <span>
            <span class="block font-mono text-xs uppercase tracking-wider text-steel-500">Based in</span>
            <span class="text-cream">{site.cityState} · serving Northeast Mississippi</span>
          </span>
        </div>
      </div>

      <p class="mt-8 font-mono text-xs uppercase tracking-wider text-steel-500">
        {site.hours}
      </p>
    </div>

    <!-- Form -->
    <div class="rounded-xl border border-steel-700 bg-steel-850 p-6 sm:p-8">
      <form id="contact-form" class="space-y-5" novalidate>
        <!-- honeypot: hidden from people, tempting to bots -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-ash">Name</label>
            <input id="name" name="name" type="text" required autocomplete="name"
              class="w-full rounded-md border border-steel-700 bg-steel-900 px-4 py-3 text-cream placeholder:text-steel-600 focus:border-arc focus:outline-none" />
          </div>
          <div>
            <label for="phone" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-ash">Phone</label>
            <input id="phone" name="phone" type="tel" required autocomplete="tel"
              class="w-full rounded-md border border-steel-700 bg-steel-900 px-4 py-3 text-cream placeholder:text-steel-600 focus:border-arc focus:outline-none" />
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="email" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-ash">Email <span class="text-steel-600">(optional)</span></label>
            <input id="email" name="email" type="email" autocomplete="email"
              class="w-full rounded-md border border-steel-700 bg-steel-900 px-4 py-3 text-cream placeholder:text-steel-600 focus:border-arc focus:outline-none" />
          </div>
          <div>
            <label for="town" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-ash">Town</label>
            <input id="town" name="town" type="text" autocomplete="address-level2" placeholder="Fulton, Tupelo, Amory…"
              class="w-full rounded-md border border-steel-700 bg-steel-900 px-4 py-3 text-cream placeholder:text-steel-600 focus:border-arc focus:outline-none" />
          </div>
        </div>

        <div>
          <label for="message" class="mb-1.5 block font-mono text-xs uppercase tracking-wider text-ash">What do you need done?</label>
          <textarea id="message" name="message" rows="5" required placeholder="Welding, fabrication, excavation, trenching… tell us about the job."
            class="w-full resize-y rounded-md border border-steel-700 bg-steel-900 px-4 py-3 text-cream placeholder:text-steel-600 focus:border-arc focus:outline-none"></textarea>
        </div>

        <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark"></div>

        <button type="submit" id="submit-btn"
          class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-arc px-6 py-4 font-display text-2xl font-bold uppercase tracking-wide text-black transition-transform hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto">
          Send request
        </button>

        <p id="form-status" role="status" aria-live="polite" class="text-sm"></p>
      </form>
    </div>
  </div>
</section>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  const setStatus = (msg: string, kind: 'ok' | 'err' | 'info') => {
    if (!status) return;
    status.textContent = msg;
    status.className =
      'text-sm ' +
      (kind === 'ok' ? 'text-arc' : kind === 'err' ? 'text-spark' : 'text-ash');
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const data = new FormData(form);
    const token = data.get('cf-turnstile-response');
    if (!token) {
      setStatus('Please complete the verification box and try again.', 'err');
      return;
    }

    btn && (btn.disabled = true);
    setStatus('Sending…', 'info');

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: data });
      const json = await res.json().catch(() => ({}));
      if (res.ok && json.ok) {
        form.reset();
        // @ts-ignore - turnstile global from the cloudflare script
        if (window.turnstile) window.turnstile.reset();
        setStatus("Got it — we'll be in touch soon. For anything urgent, give us a call.", 'ok');
      } else {
        setStatus(json.error || 'Something went wrong sending that. Please call us instead.', 'err');
        btn && (btn.disabled = false);
      }
    } catch {
      setStatus('Network error. Please try again or give us a call.', 'err');
      btn && (btn.disabled = false);
    }
  });
</script>
